DHT_Unified sensore1(21, DHT22); 

// put function declarations here:

int relayPins[2] = {13,12};

bool setOutputPins(int* pins);
uint32_t delayus;

void setup() {
  // put your setup code here, to run once:
  /* pinMode(relayPins[0], OUTPUT);
  pinMode(relayPins[1], OUTPUT); */
  Serial.begin(112500);
  sensore1.begin();
  sensor_t infoSensor;
  sensore1.temperature().getSensor(&infoSensor);
  Serial.println(F("------------------------------------"));
  Serial.println(F("Temperature Sensor"));
  Serial.print  (F("Sensor Type: ")); Serial.println(infoSensor.name);
  Serial.print  (F("Driver Ver:  ")); Serial.println(infoSensor.version);
  Serial.print  (F("Unique ID:   ")); Serial.println(infoSensor.sensor_id);
  Serial.print  (F("Max Value:   ")); Serial.print(infoSensor.max_value); Serial.println(F("°C"));
  Serial.print  (F("Min Value:   ")); Serial.print(infoSensor.min_value); Serial.println(F("°C"));
  Serial.print  (F("Resolution:  ")); Serial.print(infoSensor.resolution); Serial.println(F("°C"));
  Serial.println(F("------------------------------------"));
  // Print humidity sensor details.
  sensore1.humidity().getSensor(&infoSensor);
  Serial.println(F("Humidity Sensor"));
  Serial.print  (F("Sensor Type: ")); Serial.println(infoSensor.name);
  Serial.print  (F("Driver Ver:  ")); Serial.println(infoSensor.version);
  Serial.print  (F("Unique ID:   ")); Serial.println(infoSensor.sensor_id);
  Serial.print  (F("Max Value:   ")); Serial.print(infoSensor.max_value); Serial.println(F("%"));
  Serial.print  (F("Min Value:   ")); Serial.print(infoSensor.min_value); Serial.println(F("%"));
  Serial.print  (F("Resolution:  ")); Serial.print(infoSensor.resolution); Serial.println(F("%"));
  Serial.println(F("------------------------------------"));
  // Set delay between sensor readings based on sensor details.
  delayus = infoSensor.min_delay;

}

void loop() {
  delayMicroseconds(delayus);
  sensors_event_t event;
  sensore1.temperature().getEvent(&event);
  if (isnan(event.temperature)) {
    Serial.println(F("Error reading temperature!"));
  }
  else {
    Serial.print(F("Temperature: "));
    Serial.print(event.temperature);
    Serial.println(F("°C"));
  }
  // Get humidity event and print its value.
  sensore1.humidity().getEvent(&event);
  if (isnan(event.relative_humidity)) {
    Serial.println(F("Error reading humidity!"));
  }
  else {
    Serial.print(F("Humidity: "));
    Serial.print(event.relative_humidity);
    Serial.println(F("%"));
  }




